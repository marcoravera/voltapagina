<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/base.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap-icons.css">
    <script src="/js/jquery.min.js"></script>
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script>$('#chatbox').scrollTop = $('#chatbox').scrollHeight;</script>
    <style>
        .gobackcontainer {position: fixed; top: 20px; left: 20px; z-index: 1050; }
        .central-container {max-width: 80vw; height: 80vw;}
        #chatbox {
            height: 70vh;
            overflow-y: auto;
            background-color: #f0f2f5;
            display: flex;
            flex-direction: column-reverse;
        }
        .msg {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 20px;
            margin-bottom: 10px;
            position: relative;
            font-size: 12pt;
        }
        .sent {
            background-color: #3e7e63;
            align-self: flex-end;
        }
        .received {
            background-color: #ffffff;
            align-self: flex-start;
        }
        .chat-time {
            font-size: 9pt;
            display: block;
            margin-top: 5px;
            opacity: 0.7;
        }
    </style>
</head>
<body>
<div class="gobackcontainer">
    <a href="<% if(tipo=='scambio') { %>/richieste<% } else { %>/consultazioni<% } %>" class="btn btn-light shadow-sm"><i class="bi bi-arrow-left"></i></a>
</div>
<div class="central-container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-white py-3">
                    <div class="d-flex align-items-center">
                        <div>
                            <h6 class="mb-0">
                            <% if(tipo=='scambio') { %>Scambio per: <% } else { %>Consultazione per:%><% } %><%= richiesta.libroDaRicevere.titolo %></h6>
                            <small>Stato: <strong><%= richiesta.stato %></strong></small>
                        </div>
                    </div>
                </div>

                <div id="chatbox" class="card-body p-4">
                    <div class="d-flex flex-column">
                        <% messaggi.forEach(msg => { %>
                            <div class="msg <%= msg.mittenteId.toString() === utenteLoggato.toString() ? 'sent' : 'received' %>">
                                <%= msg.testo %>
                                <span class="chat-time text-end">
                                    <%= new Date(msg.dataInvio).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                </span>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="card-footer bg-white p-3">
                    <form action="/chat/<%= richiesta._id %>/invia" method="POST" class="d-flex">
                        <input type="text" name="messaggio" class="form-control me-2" placeholder="Scrivi un messaggio..." required>
                        <button type="submit" class="btnSubmit" style="width: 20vh;">
                            <i class="bi bi-send"></i> Invia
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
</body>
</html>
